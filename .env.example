# ============================================================
# YAHA — Environment Variables Template
# Copy to .env.local and fill in values. Never commit .env.local
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Used by Supabase MCP server (npx @supabase-community/supabase-mcp)
SUPABASE_ACCESS_TOKEN=your-supabase-personal-access-token
SUPABASE_PROJECT_REF=your-project-ref

# --- Gemini AI ---
GEMINI_API_KEY=your-gemini-api-key
# Model: gemini-2.5-flash (supports text, images, audio, files)

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
# Secret token sent with every webhook request (X-Telegram-Bot-Api-Secret-Token header)
TELEGRAM_WEBHOOK_SECRET=your-random-secret-string-min-32-chars
# Comma-separated Telegram usernames allowed to log data (whitelist)
TELEGRAM_ALLOWED_HANDLES=@yourusername,@otherusername

# --- App ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-random-nextauth-secret-min-32-chars
NEXT_PUBLIC_APP_URL=http://localhost:3000
